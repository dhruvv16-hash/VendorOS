{
  "name": "VendorOS",
  "short_name": "VendorOS",
  "description": "Sleek operating system for food vendors and stalls.",
  "id": "com.vendoros.app",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#121212",
  "theme_color": "#FF6B35",
  "orientation": "portrait",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "display_override": ["tabbed", "standalone", "window-controls-overlay"],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "note_taking": {
    "new_note_url": "/?action=new-note"
  },
  "scope_extensions": [
    {
      "type": "origin",
      "origin": "https://*.vercel.app"
    }
  ],
  "categories": ["food", "business", "productivity"],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.vendoros.app",
      "id": "com.vendoros.app"
    }
  ],
  "iarc_rating_id": "e8430b80-1a73-455b-9d41-382d3149f90f",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "POS Terminal",
      "short_name": "POS",
      "description": "Launch the VendorOS Point-of-Sale terminal",
      "url": "/?tab=pos",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Orders Log",
      "short_name": "Orders",
      "description": "View live incoming orders history",
      "url": "/?tab=orders",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/mobile.png",
      "sizes": "466x843",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "VendorOS Mobile POS Terminal"
    },
    {
      "src": "/screenshots/desktop.png",
      "sizes": "390x207",
      "type": "image/png",
      "form_factor": "wide",
      "label": "VendorOS Dashboard"
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "file_handlers": [
    {
      "action": "/?action=open-receipt",
      "accept": {
        "application/json": [".vreceipt"]
      },
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+vendoros",
      "url": "/?url=%s"
    }
  ],
  "share_target": {
    "action": "/?action=share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "Sales Widget",
      "short_name": "Sales",
      "description": "VendorOS Daily Sales Statistics Widget",
      "tag": "sales-widget",
      "template": "sales-widget-template",
      "ms_ac_template": "widgets/sales.json",
      "data": "widgets/sales-data.json",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ]
}
